PORT=8000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/expense_tracker?retryWrites=true&w=majority
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET=your_jwt_secret_token_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # 7 days (default so users are not logged out frequently)
GOOGLE_CLIENT_ID=your_google_client_id_here

# LangSmith / LangChain Tracing Configuration
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=walletwiz-backend
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
